{
  "name": "appsabore",
  "slug": "sabore-app",
  "platforms": [
    "ios",
    "android",
    "web"
  ],
  "version": "1.0.0",
  "main": "expo-router/entry",
  "homepage": "./",
  "scripts": {
    "start": "expo start",
    "electron": "concurrently \"npm run web\" \"wait-on http://localhost:19006 && electron .\"",
    "electron-dev": "electron .",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy",
    "build-web": "npx expo export -p web",
    "build-desktop": "npm run build-web && electron-builder",
    "pack-desktop": "npm run build-web && electron-builder --dir"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "^54.0.21",
    "expo-constants": "~18.0.10",
    "expo-document-picker": "~14.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-location": "~19.0.7",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "lucide-react": "^0.525.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-toastify": "^11.0.5",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@electron-forge/cli": "^7.8.3",
    "@types/react": "~19.1.10",
    "concurrently": "^9.2.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "electron-is-dev": "^3.0.1",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.4"
  },
  "private": true,
  "build": {
    "appId": "com.sabore.app",
    "productName": "Sabore",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "desktop/main.js",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.food-and-drink"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage"
    }
  }
}
