# Configurações do Backend Intermediário
PORT=4000

# URL do Backend Central (Java)
BACKEND_CENTRAL_URL=http://localhost:8080/api

# Configurações de CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081

# Timeout das requisições (em ms)
REQUEST_TIMEOUT=5000

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Ambiente (development, production)
NODE_ENV=development
